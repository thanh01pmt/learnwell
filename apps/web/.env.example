# LearnWell Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Supabase Configuration
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# Application Settings
# =============================================================================
VITE_APP_NAME=LearnWell
VITE_APP_URL=http://localhost:5173

# Enable mock data mode (no backend required)
VITE_ENABLE_MOCK_DATA=true

# Default locale (en | vi)
VITE_DEFAULT_LOCALE=vi

# =============================================================================
# Feature Flags
# =============================================================================
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_CONTESTS=true
VITE_ENABLE_GAMIFICATION=true

# =============================================================================
# External Services (Optional)
# =============================================================================
# Code execution service (Judge0 / Piston)
VITE_CODE_EXECUTION_URL=

# AI API (OpenAI / Claude)
VITE_AI_API_KEY=
VITE_AI_API_URL=

# Email service (for notifications)
# Configure in Supabase Edge Functions
